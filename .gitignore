# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Sensitive: Environment & Secrets ────────────────────────────────────────
# All .env variants — NEVER commit secrets or API keys
.env
.env.*
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging

# Secret / key files
*.key
*.pem
*.p12
*.pfx
*.cert
*.crt
secrets/
credentials/

# ─── Sensitive: Auth / Token files ───────────────────────────────────────────
auth.json
service-account*.json
firebase-adminsdk*.json
google-credentials*.json
*.token
*.secret

# ─── Sensitive: Config with credentials ──────────────────────────────────────
config/local.ts
config/local.js
config/secrets.*
src/config/local.*

# ─── Vercel / CI / Deploy ────────────────────────────────────────────────────
.vercel
.vercel-output/

# ─── TypeScript build info ───────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── OS files ────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
.Spotlight-V100
.Trashes

# ─── Editor / IDE ────────────────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.idea/
*.suo
*.user
*.swp
*.swo

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
